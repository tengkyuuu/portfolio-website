# Copy to .env.local for local dev, and set the same values in Vercel
# (Project → Settings → Environment Variables) for the deployed build.

# SHA-256 hash of your admin password. The hash ships in the client bundle;
# the plaintext never does. Generate one at /admin (the setup screen has a
# built-in hash generator), or run:
#   node -e "console.log(require('crypto').createHash('sha256').update('YOUR_PASSWORD').digest('hex'))"
VITE_ADMIN_PASSWORD_HASH=

# Server-side hash, used ONLY by the local dev API in server/app.mjs
# (npm run dev). Not used on a static Vercel deploy — safe to omit there.
ADMIN_PASSWORD_HASH=
